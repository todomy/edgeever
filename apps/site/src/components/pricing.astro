---
import { Tick } from "@/components/ui/icons";
import Link from "@/components/ui/link.astro";

const { plan } = Astro.props;
---

<div class="h-full">
  <div
    class={`flex flex-col h-full justify-between border border-slate-100 p-8 rounded-3xl glow-card hover-lift relative ${plan.popular ? 'border-brand/20 bg-gradient-to-b from-brand-soft/40 to-white' : 'bg-white'}`}>
    
    {plan.popular && (
      <div class="absolute -top-3 right-6 border border-brand-border bg-brand-muted px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider text-brand-text shadow-md shadow-brand/10">
        推荐方案
      </div>
    )}

    <div>
      <div class="text-center pb-6 border-b border-slate-100">
        <h4 class="text-base font-semibold text-slate-500 uppercase tracking-wider">{plan.name}</h4>
        <p class="mt-4 text-4xl font-extrabold text-slate-900 md:text-5xl">
          {
            plan.price && typeof plan.price === "object"
              ? plan.price.monthly
              : plan.price
          }
        </p>
      </div>
      
      <ul class="grid mt-8 text-left gap-y-4">
        {
          plan.features.map((item) => (
            <li class="flex items-start gap-3 text-slate-600 text-sm">
              <span class="bg-brand-soft rounded-full p-0.5 shrink-0 flex items-center justify-center border border-brand-border/20 mt-0.5">
                <Tick class="w-4.5 h-4.5 text-brand" />
              </span>
              <span class="leading-relaxed">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="flex mt-10">
      <Link
        href={plan.button.link || "#"}
        block
        style={plan.popular ? "primary" : "outline"}
        class={`w-full text-center py-3 rounded-xl font-semibold shadow-sm transition-all hover:scale-[1.01] ${plan.popular ? 'shadow-brand/10' : 'border border-slate-200 hover:bg-slate-50'}`}>
        {plan.button.text || "Get Started"}
      </Link>
    </div>
  </div>
</div>
